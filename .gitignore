# --- DATA: never publish real customer data, keep large files out of git ---
data/*.csv
data/*.xlsx
data/*.parquet
data/*.zip
data/uploads/
!data/.gitkeep
# user-local configuration (may reference private DBs); the example ships
config/segsmart.json
# a small, non-proprietary synthetic sample so clone→run works with zero setup
!data/sample_eshop.csv
# intermediate run artifacts (keep out/result.json as the baked demo)
out/eshop_result.json
out/synth_result.json

# python
__pycache__/
*.pyc
.venv/
venv/

# misc
*.bak
.DS_Store
# per-run segment snapshots (real per-customer data of whoever runs this)
out/history/
# launched mailings contain recipient lists (real customer data)
out/mailings/
# presentation working notes (not for publication)
docs/presentation-notes.md
# MBA deck credits the team by real name -> local only, never in the public repo
SegSmart_MBA_Presentation.html
